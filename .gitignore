# Python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# OS / editor
.DS_Store

# Local environments
.venv/
venv/

# Machine-specific config — points at real data outside the repo
config.json

# Local convenience folder of symlinks into a CellScope tree (real, private
# data on a public repo). Recreate with scripts/link_data.py.
data/

# Analysis outputs derived from the (private) data — figures/tables.
# Findings are summarised in committed docs/FINDINGS_*.md instead.
analysis_out/

# NEVER commit real microscopy data (it is referenced via config.json, not
# stored here). Ignore data files anywhere, then re-allow ONLY the synthetic
# sample's data files (so e.g. .DS_Store stays ignored even under sample_data).
*.ome.tif
*.tif
*.tiff
*.npz
!sample_data/**/*.tif
!sample_data/**/*.npz
